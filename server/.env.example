# PostgreSQL (використовується і сервером, і node-pg-migrate)
DATABASE_URL=postgres://localhost:5432/scba_manager_dev

# HTTP
PORT=3000

# JWT: access-токен (TTL 1 година за вимогами U-2)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_SECONDS=3600

# Refresh-токен (opaque, зберігається як sha256-hash у БД)
REFRESH_TOKEN_TTL_DAYS=30

# bcrypt cost-фактор для хешування паролів
BCRYPT_ROUNDS=10

# Продакшн (Render): CLIENT_ORIGIN вмикає CORS, якщо клієнт на іншому домені.
# Кілька origin — через кому. Локально/дев не потрібен (vite dev-proxy = same-origin).
# CLIENT_ORIGIN=https://scba-manager-client.onrender.com

# NODE_ENV=production вмикає SSL для підключення до БД (Supabase/керовані провайдери)
# NODE_ENV=production
